# On a machine where ~/.dotfiles exists (the canonical clone you edit/push), use
# it as chezmoi's source so `chezmoi apply`/`update` read what you edit — instead
# of a separate ~/.local/share/chezmoi clone. Gated by stat, so headless
# workspaces/runners (no ~/.dotfiles) fall back to the default cloned source.
{{- if stat (joinPath .chezmoi.homeDir ".dotfiles") }}
sourceDir = {{ (joinPath .chezmoi.homeDir ".dotfiles") | quote }}
{{- end }}

# Provide chezmoi template data (name/email used by dot_gitconfig.tmpl etc.)
# without ever prompting, so `chezmoi apply` / `coder dotfiles` run cleanly in
# headless environments. Override per-machine with CHEZMOI_NAME / CHEZMOI_EMAIL.
[data]
    name = {{ env "CHEZMOI_NAME" | default "Oisin Coveney" | quote }}
    email = {{ env "CHEZMOI_EMAIL" | default "git@oisin.ee" | quote }}
