{
  "$schema": "https://opencode.ai/config.json",
  "model": "broker/gpt-5.5",
  "small_model": "opencode/deepseek-v4-flash-free",
  "compaction": {
    "prune": true
  },
  "agent": {
    "build": {
      "mode": "primary",
      "prompt": "{file:./prompts/oisin.md}"
    },
    "plan": {
      "mode": "primary",
      "prompt": "{file:./prompts/oisin.md}"
    }
  },
  "mcp": {
    "pipeline-gateway": {
      "enabled": true,
      "headers": {
        "Authorization": "{env:PIPELINE_MCP_GATEWAY_AUTHORIZATION}"
      },
      "oauth": false,
      "type": "remote",
      "url": "https://pipeline-mcp.momokaya.ee/mcp/"
    },
    "playwright": {
      "command": [
        "mise",
        "exec",
        "--",
        "playwright-mcp"
      ],
      "enabled": true,
      "timeout": 20000,
      "type": "local"
    }
  },
  "plugin": [
    "@devtheops/opencode-plugin-otel@1.1.0",
    "@prevalentware/opencode-goal-plugin"
  ],
  "provider": {
    "broker": {
      "npm": "@ai-sdk/openai",
      "name": "CLIProxyAPI broker",
      "options": {
        "baseURL": "https://cliproxy.momokaya.ee/v1",
        "apiKey": "{env:BROKER_API_KEY}"
      },
      "models": {
        "gpt-5.5": {
          "options": {
            "include": [
              "reasoning.encrypted_content"
            ],
            "reasoningEffort": "medium",
            "reasoningSummary": "auto",
            "store": false,
            "textVerbosity": "medium"
          }
        },
        "gpt-5.5-low": {
          "options": {
            "include": [
              "reasoning.encrypted_content"
            ],
            "reasoningEffort": "low",
            "reasoningSummary": "auto",
            "store": false,
            "textVerbosity": "medium"
          }
        },
        "gpt-5.5-high": {
          "options": {
            "include": [
              "reasoning.encrypted_content"
            ],
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "store": false,
            "textVerbosity": "medium"
          }
        },
        "gpt-5.5-xhigh": {
          "options": {
            "include": [
              "reasoning.encrypted_content"
            ],
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto",
            "store": false,
            "textVerbosity": "medium"
          }
        }
      }
    }
  },
  "lsp": true
}
