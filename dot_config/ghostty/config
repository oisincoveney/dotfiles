# Ghostty — https://ghostty.org/docs/config
# Catppuccin Mocha + 0xProto Nerd Font (already installed under ~/Library/Fonts).

theme = Catppuccin Mocha

font-family = "0xProto Nerd Font Mono"
font-size = 14
font-thicken = true
adjust-cell-height = 12%

# Cursor
cursor-style = block
cursor-style-blink = true
shell-integration-features = cursor,sudo,title

# Window chrome — roomy padding, translucent, native macOS feel.
window-padding-x = 14
window-padding-y = 10
window-padding-balance = true
background-opacity = 0.95
background-blur-radius = 20
macos-titlebar-style = tabs
macos-option-as-alt = true

# Animated cursor-trail shader (vendored in shaders/). Small GPU cost; delete
# these two lines to disable.
custom-shader = shaders/cursor_blaze.glsl
custom-shader-animation = true
window-colorspace = display-p3

# Splits + quick terminal
unfocused-split-opacity = 0.88
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+opt+left=goto_split:left
keybind = cmd+opt+right=goto_split:right
keybind = cmd+opt+up=goto_split:up
keybind = cmd+opt+down=goto_split:down
keybind = cmd+enter=toggle_split_zoom
quick-terminal-position = top
keybind = global:cmd+grave_accent=toggle_quick_terminal

# Behaviour
copy-on-select = clipboard
confirm-close-surface = false
mouse-hide-while-typing = true
window-save-state = always
