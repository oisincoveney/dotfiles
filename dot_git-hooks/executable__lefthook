#!/usr/bin/env sh
set -eu

hook_name="${1:-}"
if [ -z "$hook_name" ]; then
  exit 0
fi
shift

if [ "${LEFTHOOK:-}" = "0" ]; then
  exit 0
fi

# Skip silently when this repo has no lefthook config. Otherwise lefthook prints a
# "No config files ... found" notice to stderr on every git action (commit, push,
# checkout, merge) in every non-lefthook repo — once per hook stage.
config_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -n "$config_root" ]; then
  found_config=
  for base in lefthook .lefthook .config/lefthook; do
    for ext in yml yaml json toml; do
      if [ -e "$config_root/$base.$ext" ]; then
        found_config=1
        break 2
      fi
    done
  done
  [ -n "$found_config" ] || exit 0
fi

if [ -n "${LEFTHOOK_BIN:-}" ]; then
  exec "$LEFTHOOK_BIN" run "$hook_name" "$@"
fi

if command -v lefthook >/dev/null 2>&1; then
  exec lefthook run "$hook_name" "$@"
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -n "$repo_root" ]; then
  os_arch="$(uname | tr '[:upper:]' '[:lower:]')"
  cpu_arch="$(uname -m | sed 's/aarch64/arm64/;s/x86_64/x64/')"

  for candidate in \
    "$repo_root/node_modules/lefthook-${os_arch}-${cpu_arch}/bin/lefthook" \
    "$repo_root/node_modules/@evilmartians/lefthook/bin/lefthook-${os_arch}-${cpu_arch}/lefthook" \
    "$repo_root/node_modules/@evilmartians/lefthook-installer/bin/lefthook" \
    "$repo_root/node_modules/lefthook/bin/index.js"
  do
    if [ -x "$candidate" ]; then
      exec "$candidate" run "$hook_name" "$@"
    fi
  done
fi

if command -v mise >/dev/null 2>&1 && mise exec -- lefthook -h >/dev/null 2>&1; then
  exec mise exec -- lefthook run "$hook_name" "$@"
fi

if command -v uv >/dev/null 2>&1 && uv run lefthook -h >/dev/null 2>&1; then
  exec uv run lefthook run "$hook_name" "$@"
fi

exit 0
