# Never track AI-tool state, history, caches, or secrets that live alongside
# the configs we manage (these dirs hold multi-GB sqlite logs + auth tokens).
**/*.sqlite
**/*.sqlite-shm
**/*.sqlite-wal
**/auth.json
**/*.credentials.json
**/history.jsonl
.claude/projects
.claude/sessions
.claude/session-env
.claude/file-history
.claude/paste-cache
.claude/plans
.claude/backups
.claude/todos
.claude/statsig
.config/opencode/node_modules
.config/opencode/plugins

# The Mac's Claude settings.json is managed by local apps (Muxy/herdr/orca
# hooks with Mac-absolute paths); only deploy the portable settings off-darwin.
{{ if eq .chezmoi.os "darwin" }}
.claude/settings.json
{{ end }}

# AI-config-only mode (CHEZMOI_AI_ONLY=1): used by the headless moka
# pipeline-runner. Deploy ONLY the AI tool config (rules + opencode/codex/gemini)
# and exclude git identity/hooks, ssh, and the interactive shell/editor setup so
# the bot's git identity and automated git ops are never touched. Pair with
# `chezmoi apply --exclude=scripts` to skip the run_once installers.
{{ if env "CHEZMOI_AI_ONLY" }}
.gitconfig
.git-hooks
.ssh
.zshrc
.zshenv
.zprofile
.profile
.config/zsh
.config/tmux
.config/nvim
.config/zellij
.config/mise
.rulesync
{{ end }}
