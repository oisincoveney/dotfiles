# Coder dev-workspace only (REPO_DIR set): the codex coder module owns
# ~/.codex/config.toml — it writes the dev model provider (OpenRouter) and the
# cloned-repo trust entry there BEFORE codex starts. chezmoi must not clobber it
# with the laptop config (gpt-5.5 + no provider), which both breaks the model and
# re-introduces the "Do you trust this directory?" prompt. No-op on laptops.
{{ if env "REPO_DIR" }}
.codex/config.toml
{{ end }}

# The Mac's Claude settings.json is managed by local apps (Muxy/herdr/orca
# hooks with Mac-absolute paths); only deploy the portable settings off-darwin.
{{ if eq .chezmoi.os "darwin" }}
.claude/settings.json
{{ end }}

# AI-config-only mode (CHEZMOI_AI_ONLY=1): used by the headless moka
# pipeline-runner. Deploy ONLY the AI tool config (rules + opencode/codex/gemini)
# and exclude git identity/hooks, ssh, and the interactive shell/editor setup so
# the bot's git identity and automated git ops are never touched. Pair with
# `chezmoi apply --exclude=scripts` to skip the run_once installers.
{{ if env "CHEZMOI_AI_ONLY" }}
.gitconfig
.git-hooks
.ssh
.zshrc
.zshenv
.zprofile
.profile
.config/zsh
.config/tmux
.config/nvim
.config/zellij
.config/mise
.rulesync
{{ end }}
