[[ -r "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# uv
export PATH="$HOME/.local/bin:$PATH"
export MISE_SYSTEM_CONFIG_FILE="$HOME/.config/mise/agent.toml"

# Machine-local, non-public overrides (e.g. internal infra endpoints). Not
# tracked here — this dotfiles repo is public. See ~/.zshenv.local.
[[ -r "$HOME/.zshenv.local" ]] && source "$HOME/.zshenv.local"

# Secrets generated by `secret sync` from OpenBao (600, gitignored). Sourced
# here so non-interactive shells (agents, CI, subprocesses) get them too, not
# just interactive .zshrc. No-ops on machines where secrets were never synced.
[[ -r "${XDG_CONFIG_HOME:-$HOME/.config}/zsh/secrets.zsh" ]] && source "${XDG_CONFIG_HOME:-$HOME/.config}/zsh/secrets.zsh"
