#!/bin/bash
# Install core packages on a fresh machine
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
# ── macOS: Homebrew ──────────────────────────────────────────────────

if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> "$HOME/.zprofile"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# The full package set is the single source of truth in ~/.config/Brewfile
# (+ Brewfile.fonts). It's installed by run_onchange_after_02-brew-bundle, which
# re-runs automatically whenever either Brewfile changes.
echo "Homebrew ready; packages are applied by the Brewfile bundle step."

{{ else if eq .chezmoi.os "linux" -}}
# ── Linux: core packages ─────────────────────────────────────────────

# Use sudo only when we are not already root and sudo exists. Container/Nix
# images often run as a non-root user with no sudo; on those the package
# manager is also absent and the tools are baked into the image, so we skip.
SUDO=""
if [ "$(id -u)" -ne 0 ] && command -v sudo &>/dev/null; then
  SUDO="sudo"
fi

if command -v apt-get &>/dev/null; then
  $SUDO apt-get update -qq
  $SUDO apt-get install -y -qq bat curl fd-find fzf gh git ripgrep tmux unzip xclip zoxide zsh
elif command -v dnf &>/dev/null; then
  $SUDO dnf install -y bat git curl zsh fzf ripgrep tmux unzip zoxide
elif command -v pacman &>/dev/null; then
  $SUDO pacman -Syu --noconfirm bat eza git curl zsh fzf ripgrep tmux unzip zoxide
else
  echo "No supported package manager (apt/dnf/pacman); assuming the image provides these tools."
fi

# Install zoxide
if ! command -v zoxide &>/dev/null; then
  curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# Install mise
if ! command -v mise &>/dev/null; then
  curl https://mise.run | sh
fi

# Install starship (prompt).
if ! command -v starship &>/dev/null; then
  curl -sS https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin"
fi

# Install atuin (shell history).
if ! command -v atuin &>/dev/null; then
  curl -sSfL https://setup.atuin.sh | sh 2>/dev/null || echo "Install atuin manually: https://atuin.sh"
fi

# Install eza (modern ls) where the distro didn't provide it.
if ! command -v eza &>/dev/null; then
  cargo install eza 2>/dev/null || echo "Install eza manually: https://github.com/eza-community/eza"
fi

# Install delta
if ! command -v delta &>/dev/null; then
  cargo install git-delta 2>/dev/null || echo "Install delta manually: https://github.com/dandavison/delta"
fi

echo "Linux packages installed."
{{ end -}}
