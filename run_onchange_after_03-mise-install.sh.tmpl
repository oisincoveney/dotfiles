#!/bin/bash
# Install/sync the mise tool set whenever the human mise fragment changes. This is
# the cross-platform half of the setup: mise merges conf.d/*.toml (the human
# fragment here + the agent fragment pulled from GitHub by the chezmoi external) and
# drives identical tools on macOS and every Linux box, via mise's aqua/github/cargo
# backends (prebuilt binaries, no Homebrew-on-Linux needed).
#
# A GitHub token is passed through so mise's github/aqua backends don't trip the
# unauthenticated GitHub rate limit while fetching ~35 tools (best-effort: uses an
# existing $GITHUB_TOKEN, else the gh CLI login, else proceeds unauthenticated).
#
# `cza` refreshes the agent fragment (10-agent.toml) via the external before this
# after-script runs, so `mise install` below sees both current fragments. Track both
# inputs in this script's rendered content so either toolset change triggers it.
# human mise config hash: {{ include "dot_config/mise/conf.d/20-human.toml" | sha256sum }}
# agent mise config blob: {{ output "sh" "-c" "gh api 'repos/oisin-ee/agent/contents/mise/mise.toml?ref=main' --jq .sha 2>/dev/null || echo unknown" | trim }}
set -euo pipefail

command -v mise >/dev/null 2>&1 || { echo "mise not installed; skipping tool sync."; exit 0; }

export GITHUB_TOKEN="${GITHUB_TOKEN:-$(gh auth token 2>/dev/null || true)}"

echo "Syncing mise tools…"
mise install -y 
mise up
echo "mise tool sync complete."
