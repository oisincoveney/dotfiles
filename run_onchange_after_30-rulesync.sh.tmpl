#!/bin/bash
# Regenerate AGENTS.md / CLAUDE.md and per-tool rule files from ~/.rulesync/
# using rulesync. Runs on every chezmoi apply whenever the rulesync source
# files change (chezmoi onchange hash tracks the template content below).
#
# Pinned rulesync version: 8.19.0
# rulesync config hash: {{ include "rulesync.jsonc" | sha256sum }}
# rules hash: {{ include "dot_rulesync/rules/global.md" | sha256sum }}{{ include "dot_rulesync/rules/behavior.md" | sha256sum }}{{ include "dot_rulesync/rules/coding-style.md" | sha256sum }}{{ include "dot_rulesync/rules/anti-patterns.md" | sha256sum }}{{ include "dot_rulesync/rules/verification.md" | sha256sum }}
set -euo pipefail

# Always run rulesync through the pinned npx invocation so the exact version
# (8.19.0) is enforced on every workstation regardless of what may be on PATH.
if ! command -v npx &>/dev/null; then
  echo "npx not found; skipping rule generation (install Node.js to enable)" >&2
  exit 0
fi

RULESYNC="npx --yes rulesync@8.19.0"

echo "Running rulesync generate (pinned: $RULESYNC)..."
$RULESYNC generate
echo "rulesync: rules written to ~/.claude/CLAUDE.md, ~/.codex/AGENTS.md, etc."
