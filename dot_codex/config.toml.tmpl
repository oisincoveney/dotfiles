# codex config — portable defaults managed by chezmoi.
# Mac-absolute [projects.*] and [hooks.state.*] blocks are stripped here;
# codex accumulates them locally as you work.
personality = "pragmatic"
model = "gpt-5.5"
model_reasoning_effort = "high"
plan_mode_reasoning_effort = "high"

[tui]
status_line = [
    "model-with-reasoning",
    "current-dir",
    "model",
    "git-branch",
    "pull-request-number",
    "five-hour-limit",
    "weekly-limit",
    "context-remaining",
    "context-used",
    "context-window-size",
]
status_line_use_colors = true

[notice]
hide_rate_limit_model_nudge = true

[features]
hooks = true
apps = false
{{ if env "REPO_DIR" }}
# Coder dev-workspace: trust the cloned repo so the interactive codex TUI starts
# at the prompt instead of the "Do you trust this folder?" dialog. REPO_DIR is
# exported by the dev-workspace agent env; this block is absent on laptops.
[projects."{{ env "REPO_DIR" }}"]
trust_level = "trusted"
{{ end }}
