# Agent-functional mise toolset — pulled from the canonical GitHub oisin-ee/agent
# repo (NOT the local ~/dev/agent checkout) and installed as mise's lower-precedence
# system config. The writable human global config overrides it without a generator or
# committed merged manifest. `cza` (chezmoi apply
# --refresh-externals=always) re-pulls this every apply, so the environment's agent
# toolset regenerates from GitHub on each cza. .chezmoiexternal.$FORMAT is always a
# template, so the private-repo token is injected from `gh auth token` at apply time.
[".config/mise/agent.toml"]
    type = "archive-file"
    url = "https://oauth2:{{ output "gh" "auth" "token" | trim }}@github.com/oisin-ee/agent/archive/refs/heads/main.tar.gz"
    path = "agent-main/mise/mise.toml"
    refreshPeriod = "24h"
