#!/usr/bin/env bash
# secret — one-command laptop secret management, backed by OpenBao.
#
#   secret set NAME [value]   store a secret (prompts hidden if value omitted) + resync
#   secret rm  NAME           delete a secret + resync
#   secret ls                 list secret names
#   secret get NAME           print a secret value (explicit)
#   secret sync               regenerate ~/.config/zsh/secrets.zsh from OpenBao
#
# OpenBao is the single source of truth. Laptop-only secrets live by CONVENTION at
# kv/laptop-env/<NAME>#value — no map to edit, no path to choose. `secret sync`
# auto-discovers them and writes the generated (600, gitignored) secrets.zsh that
# .zshrc sources last. Secrets also consumed by pods live at their canonical shared
# path and are listed in SHARED below (rare); pods get those via external-secrets.
set -euo pipefail

MOUNT=kv
PREFIX=laptop-env
OUT="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/secrets.zsh"

# Pod-shared secrets: VAR  path#field (only for secrets ALSO delivered to pods).
SHARED="
BROKER_API_KEY agent-runtime/pipeline-runner/broker-api-key#api-key
VERDACCIO_NPM_AUTH_READ app-runtime/verdaccio/verdaccio/reader-auth#npm-auth
"

die() { echo "secret: $*" >&2; exit 1; }

need_bao() {
  command -v bao >/dev/null 2>&1 || die "bao CLI not found"
  bao token lookup >/dev/null 2>&1 || die "not authenticated to OpenBao (check BAO_ADDR, run 'bao login')"
}

# single-quote a value for safe shell sourcing (handles embedded single quotes)
sq() { printf "'%s'" "${1//\'/\'\\\'\'}"; }

sync_secrets() {
  need_bao
  local tmp; tmp="$(mktemp "${OUT}.XXXXXX")"
  trap 'rm -f "$tmp"' RETURN
  {
    echo "# GENERATED by \`secret sync\` from OpenBao — DO NOT EDIT."
    echo "# Add: secret set NAME    Remove: secret rm NAME    List: secret ls"
  } >"$tmp"
  # pod-shared (explicit path#field)
  while read -r var ref; do
    [ -z "${var:-}" ] && continue
    local p="${ref%#*}" f="${ref##*#}" v
    if v="$(bao kv get -mount="$MOUNT" -field="$f" "$p" 2>/dev/null)"; then
      printf 'export %s=%s\n' "$var" "$(sq "$v")" >>"$tmp"
    else
      echo "secret: warn: shared $var missing ($p#$f)" >&2
    fi
  done <<EOF
$SHARED
EOF
  # laptop-only (convention: kv/laptop-env/<NAME>#value)
  local name v
  for name in $(bao kv list -mount="$MOUNT" -format=json "$PREFIX" 2>/dev/null | jq -r '.[]?'); do
    if v="$(bao kv get -mount="$MOUNT" -field=value "$PREFIX/$name" 2>/dev/null)"; then
      printf 'export %s=%s\n' "$name" "$(sq "$v")" >>"$tmp"
    else
      echo "secret: warn: $name unreadable" >&2
    fi
  done
  chmod 600 "$tmp"; mv "$tmp" "$OUT"; trap - RETURN
  echo "secret: synced → $OUT"
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  set)
    name="${1:?usage: secret set NAME [value]   (non-interactive: printf %s VALUE | secret set NAME)}"; shift || true
    # Value source, in priority order:
    #   1. inline arg     — quick, but visible in argv/shell history
    #   2. piped stdin     — non-interactive (agents/scripts), nothing in argv; $(cat) strips trailing newline
    #   3. hidden prompt   — interactive tty
    if [ "$#" -gt 0 ]; then val="$1"
    elif [ ! -t 0 ]; then val="$(cat)"
    else printf 'value for %s: ' "$name" >&2; read -rs val; echo >&2
    fi
    [ -n "${val:-}" ] || die "empty value"
    need_bao; bao kv put -mount="$MOUNT" "$PREFIX/$name" value="$val" >/dev/null
    echo "secret: stored $name"; sync_secrets
    ;;
  rm|delete)
    name="${1:?usage: secret rm NAME}"
    need_bao; bao kv metadata delete -mount="$MOUNT" "$PREFIX/$name" >/dev/null
    echo "secret: removed $name"; sync_secrets
    ;;
  ls|list)
    need_bao
    echo "laptop-env:"; bao kv list -mount="$MOUNT" -format=json "$PREFIX" 2>/dev/null | jq -r '.[]? | "  " + .'
    echo "shared:"; echo "$SHARED" | awk 'NF{print "  " $1}'
    ;;
  get)
    name="${1:?usage: secret get NAME}"; need_bao
    bao kv get -mount="$MOUNT" -field=value "$PREFIX/$name"
    ;;
  sync) sync_secrets ;;
  *) echo "usage: secret {set|rm|ls|get|sync}"; echo "  secret set NAME [value] | secret rm NAME | secret ls | secret get NAME | secret sync" ;;
esac
