#!/usr/bin/env bash
# secrets-sync — regenerate ~/.config/zsh/secrets.zsh from OpenBao.
#
# OpenBao is the single source of truth: add a secret once (`bao kv put -mount=kv
# <path> <field>=<value>`) and it flows to the cluster/pods (via external-secrets)
# and to this laptop (via this script). The generated secrets.zsh is still what
# .zshrc sources last, so shell startup stays instant and offline-safe — but it is
# GENERATED, never hand-edited. Edit OpenBao and re-run `secrets-sync`.
#
# The VAR→path#field map below is not secret (paths aren't secrets), so it lives
# in the tracked dotfiles. Only the generated output holds values, and it is
# gitignored + chmod 600.
set -euo pipefail

# ── Declarative map: ENV_VAR  kv-path#field (mount is kv/, v2) ─────────────────
# One row per secret; this table is the single owner of the var→location axis.
SECRETS="
BROKER_API_KEY                     agent-runtime/pipeline-runner/broker-api-key#api-key
PIPELINE_MCP_GATEWAY_AUTHORIZATION agent-runtime/laptop/mcp-gateway#authorization
UIDOTSH_TOKEN                      agent-runtime/laptop/uidotsh#token
EXA_API_KEY                        agent-runtime/laptop/exa#api-key
"

command -v bao >/dev/null 2>&1 || { echo "secrets-sync: bao CLI not found" >&2; exit 1; }
# Auth preflight — a hard failure here (unset BAO_ADDR / expired token / sealed)
# is distinct from a not-yet-populated secret below, which is only a warning.
bao token lookup >/dev/null 2>&1 || {
  echo "secrets-sync: not authenticated to OpenBao (check BAO_ADDR and run 'bao login')" >&2
  exit 1
}

out="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/secrets.zsh"
tmp="$(mktemp "${out}.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

# single-quote a value for safe shell sourcing (handles embedded single quotes)
sq() { printf "'%s'" "${1//\'/\'\\\'\'}"; }

{
  echo "# GENERATED by secrets-sync from OpenBao — DO NOT EDIT."
  echo "# Add/change a secret: bao kv put -mount=kv <path> <field>=<value> && secrets-sync"
  echo "# Map lives in ~/.local/bin/secrets-sync (tracked); this file is gitignored + 600."
} >"$tmp"

missing=0
while read -r var ref; do
  [ -z "${var:-}" ] && continue
  path="${ref%#*}"; field="${ref##*#}"
  if val="$(bao kv get -mount=kv -field="$field" "$path" 2>/dev/null)"; then
    printf 'export %s=%s\n' "$var" "$(sq "$val")" >>"$tmp"
  else
    echo "secrets-sync: warn: $var not yet in OpenBao ($path#$field) — skipping" >&2
    missing=$((missing + 1))
  fi
done <<EOF
$SECRETS
EOF

chmod 600 "$tmp"
mv "$tmp" "$out"
trap - EXIT
echo "secrets-sync: wrote $out ($((missing)) secret(s) not yet populated)"
